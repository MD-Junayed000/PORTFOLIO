# Backend Environment Variables
# Copy this file to .env and fill in the values.

# REQUIRED: Secret key for JWT token signing.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# HuggingFace API token for the RAG chatbot inference.
# Get one at https://huggingface.co/settings/tokens
HF_API_TOKEN=

# HuggingFace model ID for text generation (default: meta-llama/Meta-Llama-3-8B-Instruct)
HF_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct

# Database URL (default: sqlite+aiosqlite:///./portfolio.db)
DATABASE_URL=sqlite+aiosqlite:///./portfolio.db

# ChromaDB persistence directory (default: ./chroma_data)
CHROMA_PERSIST_DIR=./chroma_data

# CORS allowed origins (comma-separated list)
# Example: http://localhost:3000,https://your-frontend-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin credentials
ADMIN_USERNAME=admin
# Generate a password hash with:
# python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-secure-password'))"
ADMIN_PASSWORD_HASH=
