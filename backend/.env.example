# ============================================
# Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Security (REQUIRED for production) ---
# Secret key for JWT token signing.
# REQUIRED: The app will NOT start without this in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# --- Admin Credentials ---
ADMIN_USERNAME=admin
# IMPORTANT: Change this before deploying to production!
# The default hash (if left empty in .env) corresponds to "admin123" which is NOT SECURE.
# Generate a new hash with:
#   python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-secure-password'))"
ADMIN_PASSWORD_HASH=

# --- HuggingFace Configuration ---
# Required: Get your token from https://huggingface.co/settings/tokens
HF_API_TOKEN=your-huggingface-api-token
# Model to use for chat responses
HF_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3

# --- Storage ---
# ChromaDB persistent storage directory
CHROMA_PERSIST_DIR=./chroma_data
# SQLAlchemy database URL
DATABASE_URL=sqlite+aiosqlite:///./portfolio.db

# --- CORS ---
# Allowed origins as JSON array.
# For production, set to your specific Vercel frontend URL.
CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
# Optional: regex pattern for Vercel preview deployments.
# Example: https://portfolio-junayed(-[a-z0-9]+)?\.vercel\.app
# CORS_ORIGIN_REGEX=

# --- Upload Limits ---
# MAX_PHOTO_SIZE=10485760
# MAX_PDF_SIZE=52428800

# --- Testing ---
# Set to true only in test environments (allows default SECRET_KEY)
# TESTING=true

# --- Server ---
# Port for the server (automatically set by Render in production)
# PORT=8000
